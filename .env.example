# Copy this file to .env and fill in your key. NEVER commit the real .env.
#
# Note: the Hack-Nation OpenAI "credit" (e.g. MVKN...) is a billing coupon you
# redeem on the OpenAI platform to fund your account. It is NOT the API key.
# After redeeming it, create a normal API key and paste it below.

OPENAI_API_KEY=sk-your-openai-api-key-here
